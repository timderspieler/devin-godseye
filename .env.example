# --- Devin API ---
# Personal or service API key from https://app.devin.ai/settings/api-keys
DEVIN_API_KEY=
DEVIN_API_BASE_URL=https://api.devin.ai

# --- GitHub ---
# Token with `repo` scope (needed to close declined issues + post comments).
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
# Shared secret configured on the GitHub webhook (HMAC verification).
GITHUB_WEBHOOK_SECRET=
# Repo the automation watches (used for the prompt link / defaults).
TARGET_REPO=timderspieler/superset

# --- Labels ---
# Comma-separated labels that trigger the automation when added to an issue.
TRIGGER_LABELS=devin-fix
# Comma-separated labels that auto-approve (skip manual review).
AUTO_APPROVE_LABELS=

# --- Storage / polling ---
DATABASE_URL=sqlite:///./data/godseye.db
POLL_INTERVAL_SECONDS=30
# Optional ACU cap per created session (leave blank for account default).
SESSION_MAX_ACU_LIMIT=
